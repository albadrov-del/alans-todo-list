{
  "name": "alans-todo-list",
  "version": "1.0.0",
  "description": "Alan's To Do List with authentication",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "test:watch": "cross-env NODE_ENV=test jest --runInBand --watch",
    "test:e2e": "cross-env NODE_ENV=test playwright test",
    "test:all": "npm test && npm run test:e2e"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "cross-env": "^7.0.3",
    "docx": "^9.5.3",
    "jest": "^29.7.0",
    "pdfkit": "^0.17.2",
    "supertest": "^7.0.0"
  }
}
